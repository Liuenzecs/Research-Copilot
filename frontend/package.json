{
  "name": "research-copilot-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "npm run desktop:clean",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "desktop:dev": "node ./scripts/run-tauri-with-build-metadata.mjs dev",
    "desktop:build": "node ./scripts/run-tauri-with-build-metadata.mjs build",
    "desktop:clean": "node ./scripts/clean-desktop-artifacts.mjs",
    "desktop:build:fresh": "npm run desktop:clean && npm run desktop:build",
    "desktop:backend:bundle": "powershell -NoLogo -NoProfile -ExecutionPolicy Bypass -File ./scripts/bundle-desktop-backend.ps1",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-query": "^5.91.3",
    "@tauri-apps/api": "^2.1.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "^7.6.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.2",
    "@tauri-apps/cli": "^2.1.0",
    "@types/node": "22.15.21",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "5.8.3",
    "vite": "^7.0.0"
  }
}
